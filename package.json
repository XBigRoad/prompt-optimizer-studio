{
  "name": "prompt-optimizer-studio",
  "version": "0.1.6",
  "private": true,
  "engines": {
    "node": "22.22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs",
    "check:architecture": "dependency-cruiser --config dependency-cruiser.cjs src && node scripts/check-architecture.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "check": "npm run lint && npm run check:architecture && npm run typecheck && npm run test && npm run build",
    "demo:seed": "node --import tsx scripts/seed-demo-data.ts"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.18",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^10.1.0",
    "eslint-config-next": "^16.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1"
  },
  "license": "AGPL-3.0-only"
}
